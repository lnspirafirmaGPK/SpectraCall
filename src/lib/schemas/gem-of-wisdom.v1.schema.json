{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inspirafirma.com/schemas/asi/gem-of-wisdom.v1.json",
  "title": "ASI Gem of Wisdom",
  "description": "มาตรฐานโครงสร้างข้อมูลสำหรับผลึกภูมิปัญญา (Postmortem Learning Package) เพื่อใช้แพตช์นโยบายและป้องกันการเกิดข้อผิดพลาดซ้ำในสถาปัตยกรรม AETHERIUM GENESIS",
  "type": "object",
  "required": [
    "gem_id",
    "metadata",
    "context_origin",
    "crystallization_ritual",
    "patch_payload",
    "verification_metrics"
  ],
  "properties": {
    "gem_id": {
      "type": "string",
      "pattern": "^GEM-[A-Z0-9]{4}-[A-Z0-9]{8}$",
      "description": "รหัสระบุผลึกภูมิปัญญา (เช่น GEM-DEPT-1234ABCD)"
    },
    "metadata": {
      "type": "object",
      "required": ["version", "status", "created_at", "author_agent"],
      "properties": {
        "version": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "status": {
          "type": "string",
          "enum": ["draft", "compliance_review", "approved", "active", "archived", "rolled_back"]
        },
        "created_at": { "type": "string", "format": "date-time" },
        "author_agent": {
          "type": "string",
          "description": "รหัสของ Agent (เช่น AgioSage) หรือมนุษย์ที่สร้าง Gem นี้"
        }
      }
    },
    "context_origin": {
      "type": "object",
      "description": "ต้นกำเนิดของข้อผิดพลาดที่นำมาสู่การตกผลึกความรู้นี้",
      "required": ["incident_id", "root_cause_category", "description"],
      "properties": {
        "incident_id": { "type": "string", "description": "อ้างอิงไปยัง Replay/Trace ID ต้นเรื่อง" },
        "root_cause_category": {
          "type": "string",
          "enum": [
            "prompt_flaw",
            "tool_misuse",
            "schema_drift",
            "policy_ambiguity",
            "logic_fallacy",
            "resonance_divergence"
          ]
        },
        "description": { "type": "string", "maxLength": 1000 }
      }
    },
    "crystallization_ritual": {
      "type": "object",
      "description": "กระบวนการทางปัญญาที่ใช้แปรธาตุข้อมูล",
      "required": ["mode", "emotional_tone", "reflection_focus", "human_alignment"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["Prophetic", "Philosophical", "Poetic", "Strict_Logic"]
        },
        "emotional_tone": { "type": "string" },
        "reflection_focus": { "type": "string", "description": "แก่นแท้ของปรัชญาที่ระบบเรียนรู้" },
        "human_alignment": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Principle A: Non-Harm", "Principle B: Efficiency", "Principle C: Truthfulness"]
          }
        }
      }
    },
    "patch_payload": {
      "type": "object",
      "description": "แพ็กเกจการบังคับใช้จริงที่เครื่องจักรนำไปประมวลผลต่อได้ (Actionable Artifact)",
      "required": ["patch_type", "rollout_scope", "rules"],
      "properties": {
        "patch_type": {
          "type": "string",
          "enum": ["contract_patch", "schema_rule", "tool_restriction", "system_prompt_modifier"]
        },
        "rollout_scope": {
          "type": "string",
          "enum": ["agent_only", "department", "org_wide"]
        },
        "rules": {
          "type": "object",
          "description": "บรรจุโค้ด OPA/Rego, JSON Schema Patch หรือคำสั่งระงับ Tool"
        }
      }
    },
    "verification_metrics": {
      "type": "object",
      "description": "ตัวชี้วัดความสำเร็จเพื่อพิสูจน์ว่า Gem นี้ใช้งานได้จริง",
      "required": ["target_resonance_improvement", "acceptable_repeat_rate"],
      "properties": {
        "target_resonance_improvement": { "type": "number", "minimum": 0, "maximum": 100 },
        "acceptable_repeat_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "เป้าหมายอัตราการเกิดซ้ำที่ยอมรับได้ (เช่น 0.01)"
        },
        "rollback_threshold": {
          "type": "number",
          "description": "หาก Drift Score เกินค่านี้ ให้ทำการ Rollback Gem อัตโนมัติ"
        }
      }
    }
  }
}
